generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// O "Dicionário" (Dados que vêm do CSV)
model FifaPlayer {
  id       Int     @id
  name     String
  overall  Int
  position String
  age      Int
  nation   String?
  league   String?
  team     String?

  // Atributos principais
  pace        Int?
  shooting    Int?
  passing     Int?
  dribbling   Int?
  defending   Int?
  physicality Int?

  // Perfil físico e habilidades
  height        Int?
  weight        Int?
  preferredFoot String?
  weakFoot      Int?
  skillMoves    Int?
  playstyle     String?
  altPositions  String?

  // Atributos de Goleiro
  gkDiving      Int?
  gkHandling    Int?
  gkKicking     Int?
  gkPositioning Int?
  gkReflexes    Int?

  @@map("fifa_players")
}

// Elenco Atual (Dados Mutáveis)
model SquadPlayer {
  id             String @id @default(cuid())
  fifaPlayerId   Int? // ID original do jogo (para puxar foto depois se quiser)
  name           String // Salvamos o nome para leitura rápida
  position       String
  currentOverall Int // O overall atual no save (que vai evoluir)

  // Estatísticas da temporada
  goals       Int @default(0)
  assists     Int @default(0)
  matches     Int @default(0)
  yellowCards Int @default(0)
  redCards    Int @default(0)
  cleanSheets Int @default(0)

  // Contrato & finanças (valores em milhares de €)
  marketValue   Int @default(0) // ex: 5000 = €5M
  salary        Int @default(0) // semanal, ex: 50 = €50k/sem
  contractYears Int @default(1) // anos restantes

  // Atributos detalhados (jogadores criados manualmente)
  pace       Int?
  shooting   Int?
  passing    Int?
  dribbling  Int?
  defending  Int?
  physical   Int?
  age        Int?
  height     Int?
  feet       String?
  skillMoves Int?
  weakFoot   Int?
  playstyle  String?

  // Atributos de Goleiro
  gkDiving      Int?
  gkHandling    Int?
  gkKicking     Int?
  gkPositioning Int?
  gkReflexes    Int?

  // Prêmios da temporada
  awardPlayerOfSeason  Boolean @default(false)
  awardTopScorer       Boolean @default(false)
  awardBestGoalkeeper  Boolean @default(false)
  awardBestYoungPlayer Boolean @default(false)
  awardBestDefender    Boolean @default(false)
  awardBallondOr       Boolean @default(false)
  awardMonthlyBest     Int     @default(0)
  awardMotm            Int     @default(0)

  // Status no time
  isStarter Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("squad_players")
}
